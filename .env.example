# Copie para .env e preencha os valores

# Banco de dados
POSTGRES_PASSWORD=obras_dev_pass

# Segurança
SECRET_KEY=gere-uma-chave-forte-aqui

# IA
GEMINI_API_KEY=sua-chave-gemini-aqui

# Storage (S3-compatible: AWS S3, GCS, MinIO)
STORAGE_BUCKET=obras-dev
STORAGE_ENDPOINT=          # deixe vazio para AWS S3; preencha para MinIO/GCS
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1

# Ambiente
ENVIRONMENT=development

# Bases de custo (opcional na fase inicial)
SINAPI_API_URL=https://apisinapi.caixa.gov.br
SINAPI_TOKEN=
