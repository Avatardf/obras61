# ── BACKEND ────────────────────────────────────────────────────────────────────
# Fornecido automaticamente pelo Railway (PostgreSQL plugin)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/obras

# Fornecido automaticamente pelo Railway (Redis plugin)
REDIS_URL=redis://default:pass@host:6379

# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_CHAVE_SEGURA_DE_64_CHARS

# Ambiente
ENVIRONMENT=production

# CORS — permite o frontend em produção
ALLOWED_ORIGINS=["https://app.61brasil.com.br"]

# IA Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── FRONTEND ───────────────────────────────────────────────────────────────────
# URL pública do serviço backend no Railway (sem barra final)
# Copie de: Railway → backend → Settings → Public Networking → Domain
BACKEND_URL=https://obras-backend.up.railway.app
